<UserControl x:Class="SolarQuotationBillingSystem.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F0F2F5">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Card: Add New User Form -->
        <materialDesign:Card Grid.Column="0" UniformCornerRadius="8" Background="White" Padding="20" Margin="0,0,16,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Add New User" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16" />

                <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Username"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16" />

                <PasswordBox materialDesign:HintAssist.Hint="Password"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,0,0,16"
                             x:Name="PwdBox"
                             PasswordChanged="PwdBox_PasswordChanged"/>

                <ComboBox ItemsSource="{Binding Roles}"
                          SelectedItem="{Binding SelectedRole}"
                          materialDesign:HintAssist.Hint="Role"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,24" />

                <Button Command="{Binding AddUserCommand}"
                        Content="Create User"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="45"
                        materialDesign:ButtonAssist.CornerRadius="6" />
            </StackPanel>
        </materialDesign:Card>

        <!-- Right Card: User List DataGrid -->
        <materialDesign:Card Grid.Column="1" UniformCornerRadius="8" Background="White" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="System Users" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Command="{Binding LoadUsersCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="Refresh List" />
                        </StackPanel>
                    </Button>
                </DockPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding UsersList}"
                          SelectedItem="{Binding SelectedUser}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User ID" Binding="{Binding Id}" Width="80" />
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" FontSize="15" FontWeight="SemiBold" />
                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="150" />
                        <DataGridTemplateColumn Header="Action" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="Red"
                                            BorderBrush="Red"
                                            Padding="4"
                                            Height="32"
                                            ToolTip="Delete User">
                                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
