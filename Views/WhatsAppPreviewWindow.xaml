<Window x:Class="SolarQuotationBillingSystem.Views.WhatsAppPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SolarQuotationBillingSystem.Views"
        mc:Ignorable="d"
        Title="WhatsApp Preview" Height="550" Width="450" WindowStartupLocation="CenterOwner" Background="#F0F2F5">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="&#x1F4F1;" FontSize="24" Margin="0,0,10,0"/>
            <TextBlock Text="Send via WhatsApp" FontSize="20" FontWeight="SemiBold" Foreground="#075E54" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Mobile Number -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Customer Mobile Number" Foreground="#555" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding MobileNumber, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" FontSize="14" BorderBrush="#CCC" BorderThickness="1"
                     Background="White"/>
        </StackPanel>

        <!-- PDF Attachment Notice -->
        <Border Grid.Row="2" Background="#E1F5FE" BorderBrush="#03A9F4" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x1F4CE;" FontSize="18" Foreground="#0277BD" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="The PDF will be copied to your clipboard. After WhatsApp opens, press Ctrl+V to attach it!" 
                           Foreground="#01579B" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="340"/>
            </StackPanel>
        </Border>

        <!-- Message Preview -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Message Preview" Foreground="#555" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}" 
                     AcceptsReturn="True" TextWrapping="Wrap"
                     Padding="10" FontSize="14" BorderBrush="#CCC" BorderThickness="1"
                     Background="White" VerticalScrollBarVisibility="Auto" Height="220"/>
        </StackPanel>

        <!-- Action Buttons -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="#FFF" BorderBrush="#CCC" Foreground="#333"
                    Padding="0,10" FontSize="16" FontWeight="SemiBold" Cursor="Hand"/>
                    
            <Button Grid.Column="2" Content="Send" Command="{Binding SendCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="#25D366" BorderBrush="#25D366" Foreground="White"
                    Padding="0,10" FontSize="16" FontWeight="SemiBold" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
