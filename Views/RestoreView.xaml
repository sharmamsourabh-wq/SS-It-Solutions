<UserControl x:Class="SolarQuotationBillingSystem.Views.RestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F0F2F5">
    <Grid Margin="16">
        <materialDesign:Card UniformCornerRadius="8" Background="White" Padding="32" MaxWidth="700" HorizontalAlignment="Center" VerticalAlignment="Top">
            <StackPanel>
                <DockPanel Margin="0,0,0,24">
                    <materialDesign:PackIcon Kind="DatabaseImport" Width="40" Height="40" Foreground="#D32F2F" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Restore Database" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Restore your system database from a previously saved backup file (.bak or .mdf)." Foreground="{DynamicResource MaterialDesignBodyLight}" FontSize="13" />
                    </StackPanel>
                </DockPanel>

                <Separator Margin="0,0,0,24" Background="{DynamicResource MaterialDesignDivider}"/>

                <Border Background="#FFEBEE" BorderBrush="#EF5350" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Alert" Width="28" Height="28" Foreground="#C62828" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="CRITICAL WARNING: Restoring will overwrite current system data. Please ensure you have taken a backup of current data before proceeding." TextWrapping="Wrap" VerticalAlignment="Center" FontSize="13" Foreground="#B71C1C" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="SemiBold" Margin="0,0,0,24" TextWrapping="Wrap"/>

                <Button Command="{Binding PerformRestoreCommand}"
                        Content="Select Backup File &amp; Restore"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#C62828"
                        BorderBrush="#B71C1C"
                        Height="48"
                        FontSize="16"
                        materialDesign:ButtonAssist.CornerRadius="6"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
