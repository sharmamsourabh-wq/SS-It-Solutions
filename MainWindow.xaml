<Window x:Class="SolarQuotationBillingSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SolarQuotationBillingSystem"
        xmlns:viewmodels="clr-namespace:SolarQuotationBillingSystem.ViewModels"
        xmlns:views="clr-namespace:SolarQuotationBillingSystem.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Solar Quotation &amp; Billing System" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="Cambria">
    
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Data Templates for routing Views to ViewModels -->
        <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CustomerMasterViewModel}">
            <views:CustomerMasterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ProductMasterViewModel}">
            <views:ProductMasterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:QuotationViewModel}">
            <views:QuotationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:BillingViewModel}">
            <views:BillingView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:InvoiceViewModel}">
            <views:InvoiceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:InventoryViewModel}">
            <views:InventoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:PaymentsViewModel}">
            <views:PaymentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:BackupViewModel}">
            <views:BackupView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:RestoreViewModel}">
            <views:RestoreView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:UserManagementViewModel}">
            <views:UserManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:QuotationBillingModuleViewModel}">
            <views:QuotationBillingModuleView />
        </DataTemplate>
        
        <!-- Boolean to Visibility Converter for showing/hiding Shell -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <!-- LOGIN VIEW (Shown when IsLoggedIn = False) -->
        <ContentControl Content="{Binding CurrentView}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <!-- APP SHELL (Shown when IsLoggedIn = True) -->
        <materialDesign:DrawerHost x:Name="AppDrawer" IsLeftDrawerOpen="{Binding IsMenuOpen}" Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
            <materialDesign:DrawerHost.LeftDrawerContent>
                <Grid Width="250" Background="{DynamicResource MaterialDesignPaper}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Sidebar Header (Logo) -->
                    <StackPanel Grid.Row="0" Margin="16,24,16,24" Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="WhiteBalanceSunny" Width="36" Height="36" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Solar ERP" FontSize="24" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="16,0" Background="{DynamicResource MaterialDesignDivider}"/>

                    <!-- Sidebar Navigation List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,10,0,10">
                            
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavDashboardCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" Margin="0,0,16,0"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavQuotationBillingModuleCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileDocumentMultiple" Width="20" Height="20" Margin="0,0,16,0"/>
                                    <TextBlock Text="Quotation &amp; Billing" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavProductMasterCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PackageVariantClosed" Width="20" Height="20" Margin="0,0,16,0"/>
                                    <TextBlock Text="Product Master" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavPaymentsCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CashMultiple" Width="20" Height="20" Margin="0,0,16,0"/>
                                    <TextBlock Text="Payments" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavInventoryCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Warehouse" Width="20" Height="20" Margin="0,0,16,0"/>
                                    <TextBlock Text="Inventory" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavReportsCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ChartBox" Width="20" Height="20" Margin="0,0,16,0"/>
                                    <TextBlock Text="Reports" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Separator Margin="16,8" Background="{DynamicResource MaterialDesignDivider}"/>

                            <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavSettingsCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cog" Width="20" Height="20" Margin="0,0,16,0"/>
                                    <TextBlock Text="Settings" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Expander Background="Transparent" BorderThickness="0">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ShieldAccount" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Admin" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="20,0,0,0">
                                    <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavUserManagementCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AccountCog" Width="20" Height="20" Margin="0,0,16,0"/>
                                            <TextBlock Text="User Management" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavBackupCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Upload" Width="20" Height="20" Margin="0,0,16,0"/>
                                            <TextBlock Text="Backup" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavRestoreCommand}" HorizontalContentAlignment="Left" Padding="16,10" Height="45">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Download" Width="20" Height="20" Margin="0,0,16,0"/>
                                            <TextBlock Text="Restore" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </materialDesign:DrawerHost.LeftDrawerContent>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top App Bar / Header -->
                <materialDesign:ColorZone Mode="PrimaryMid" Padding="16,10" materialDesign:ElevationAssist.Elevation="Dp4" Grid.Row="0">
                    <DockPanel>
                        <!-- Sidebar Toggle Button -->
                        <ToggleButton Style="{StaticResource MaterialDesignHamburgerToggleButton}" 
                                      IsChecked="{Binding ElementName=AppDrawer, Path=IsLeftDrawerOpen}" 
                                      Margin="0,0,16,0"/>

                        <!-- App Title -->
                        <TextBlock Text="Solar Quotation &amp; Billing System" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold"/>

                        <!-- Right aligned elements -->
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Source={x:Static System:DateTime.Now}, StringFormat=f}" 
                                       xmlns:System="clr-namespace:System;assembly=mscorlib" 
                                       VerticalAlignment="Center" Margin="0,0,24,0" Opacity="0.8"/>
                            
                            <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Notifications">
                                <materialDesign:PackIcon Kind="Bell" />
                            </Button>

                            <!-- Profile Menu -->
                            <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges" StaysOpen="False" Margin="16,0,0,0">
                                <materialDesign:PopupBox.ToggleContent>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" Padding="0" Margin="0" Width="36" Height="36">
                                        <materialDesign:PackIcon Kind="AccountCircle" Width="32" Height="32"/>
                                    </Button>
                                </materialDesign:PopupBox.ToggleContent>
                                <StackPanel Width="150">
                                    <Button Content="My Profile" />
                                    <Button Content="Settings" Command="{Binding NavSettingsCommand}" />
                                    <Separator />
                                    <Button Content="Logout" Command="{Binding LogoutCommand}" Foreground="Red" />
                                </StackPanel>
                            </materialDesign:PopupBox>
                        </StackPanel>
                    </DockPanel>
                </materialDesign:ColorZone>

                <!-- Inner Content Area -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="16" />
            </Grid>
        </materialDesign:DrawerHost>
    </Grid>
</Window>
