<Application x:Class="SolarQuotationBillingSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xml:lang="en-US"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Blue" SecondaryColor="Amber" />
        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <Style TargetType="{x:Type Window}">
          <Setter Property="FontFamily" Value="Cambria" />
      </Style>
      <Style TargetType="{x:Type TextBlock}">
          <Setter Property="FontFamily" Value="Cambria" />
      </Style>
      <Style TargetType="{x:Type Control}">
          <Setter Property="FontFamily" Value="Cambria" />
      </Style>
      <Style TargetType="{x:Type materialDesign:Ripple}">
          <Setter Property="Feedback" Value="Transparent" />
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>