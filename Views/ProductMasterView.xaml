<UserControl x:Class="SolarQuotationBillingSystem.Views.ProductMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F0F2F5">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <materialDesign:DialogHost Identifier="ProductMasterDialog">

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Product Master" FontSize="28" FontWeight="Bold" Margin="0,0,0,16"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Data Entry Form -->
                <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Product Details" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            
                            <TextBox materialDesign:HintAssist.Hint="Product Name *" 
                                     Text="{Binding CurrentProduct.ProductName, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>
                                     
                            <TextBox materialDesign:HintAssist.Hint="HSN Code *" 
                                     Text="{Binding CurrentProduct.HSNCode, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>
                            
                            <TextBox materialDesign:HintAssist.Hint="Category" 
                                     Text="{Binding CurrentProduct.Category, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>
                                     
                            <TextBox materialDesign:HintAssist.Hint="Brand" 
                                     Text="{Binding CurrentProduct.Brand, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>

                            <TextBox materialDesign:HintAssist.Hint="Unit (e.g. Nos, KW, W)" 
                                     Text="{Binding CurrentProduct.Unit, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>

                            <ComboBox materialDesign:HintAssist.Hint="Tax Type" 
                                      ItemsSource="{Binding TaxTypes}" 
                                      SelectedItem="{Binding CurrentProduct.TaxType}" 
                                      Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,16"/>

                            <TextBox materialDesign:HintAssist.Hint="Price (Rate)" 
                                     Text="{Binding CurrentProduct.Price, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16"/>

                            <TextBox materialDesign:HintAssist.Hint="GST % (e.g. 18)" 
                                     Text="{Binding CurrentProduct.GST, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="DELETE" Command="{Binding DeleteCommand}" CommandParameter="{Binding CurrentProduct}" 
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="Red" BorderBrush="Red" Margin="0,0,8,0">
                                    <Button.Visibility>
                                        <Binding Path="IsEditing" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                                    </Button.Visibility>
                                </Button>
                                <Button Content="CLEAR" Command="{Binding ClearCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0"/>
                                <Button Command="{Binding SaveCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                            <Setter Property="Content" Value="SAVE"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Content" Value="UPDATE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </materialDesign:Card>

                <!-- DataGrid -->
                <materialDesign:Card Grid.Column="1" Margin="8,0,0,0" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Product List" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ProductList}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  materialDesign:DataGridAssist.CellPadding="13 8 8 8" materialDesign:DataGridAssist.ColumnHeaderPadding="8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ProductID}"/>
                                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}"/>
                                <DataGridTextColumn Header="HSN Code" Binding="{Binding HSNCode}"/>
                                <DataGridTextColumn Header="Price" Binding="{Binding Price}"/>
                                <DataGridTextColumn Header="GST %" Binding="{Binding GST}"/>
                                <DataGridTextColumn Header="Tax Type" Binding="{Binding TaxType}"/>
                                <DataGridTemplateColumn Header="Actions">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                        CommandParameter="{Binding}" ToolTip="Edit Product">
                                                    <materialDesign:PackIcon Kind="Pencil" />
                                                </Button>
                                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                        CommandParameter="{Binding}" ToolTip="Delete Product" Foreground="Red">
                                                    <materialDesign:PackIcon Kind="TrashCan" />
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
