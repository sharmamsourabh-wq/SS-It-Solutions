<UserControl x:Class="SolarQuotationBillingSystem.Views.InvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F0F2F5">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Final Invoice" FontSize="32" FontWeight="Bold" />
            <Button Command="{Binding GoBackCommand}" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                    ToolTip="Close and Go Back"
                    Foreground="{DynamicResource MaterialDesignBody}">
                <materialDesign:PackIcon Kind="Close" Width="24" Height="24" />
            </Button>
        </Grid>

        <materialDesign:Card Grid.Row="1" UniformCornerRadius="8" Background="White" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Customer Details" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding CustomerName}" FontSize="16" />
                    <TextBlock Text="{Binding Address}" />
                    <TextBlock Text="{Binding City}" />
                    <TextBlock Text="{Binding Mobile}" />
                    <TextBlock Text="{Binding GstNumber, StringFormat=GSTIN: {0}}" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding InvoiceNo, StringFormat=Invoice No: {0}}" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding InvoiceDate, StringFormat=Date: {0:dd-MMM-yyyy}}" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2" UniformCornerRadius="8" Background="White" Padding="16">
            <DataGrid ItemsSource="{Binding InvoiceItems}" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Component" Binding="{Binding Component}" />
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" />
                    <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" />
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" UniformCornerRadius="8" Background="White" Padding="16" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Payment Details Section -->
                <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,0,24,0">
                    <TextBlock Text="Payment Mode &amp; Details" FontWeight="Bold" FontSize="18" Margin="0,0,0,12" />
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Payment Mode:" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Margin="0,0,12,0"/>
                        <ComboBox ItemsSource="{Binding PaymentModes}" 
                                  SelectedItem="{Binding SelectedPaymentMode}" 
                                  Width="180" 
                                  FontSize="14" 
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsRefNoVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,4,0,0">
                        <TextBlock Text="{Binding PaymentRefLabel}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding PaymentRefNo, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="280" 
                                 HorizontalAlignment="Left" 
                                 FontSize="14" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Totals & Action Section -->
                <StackPanel Grid.Column="1" MinWidth="300">
                    <Grid Margin="0,4">
                        <TextBlock Text="Amount:" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding TotalTaxableAmount, StringFormat=₹ {0:N2}}" HorizontalAlignment="Right" FontWeight="Bold" />
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Govt Subsidy (+):" HorizontalAlignment="Left" Foreground="Green" />
                        <TextBlock Text="{Binding Subsidy, StringFormat=+ ₹ {0:N2}}" HorizontalAlignment="Right" Foreground="Green" FontWeight="Bold" />
                    </Grid>

                    <Separator Margin="0,8" />
                    <Grid Margin="0,4">
                        <TextBlock Text="Net Payable:" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding NetPayable, StringFormat=₹ {0:N2}}" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    </Grid>

                    <Separator Margin="0,8" Height="2" />
                    
                    <Grid Margin="0,8,0,4">
                        <TextBlock Text="Total CGST:" HorizontalAlignment="Left" Foreground="Gray" />
                        <TextBlock Text="{Binding TotalCGST, StringFormat=₹ {0:N2}}" HorizontalAlignment="Right" Foreground="Gray" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Total SGST:" HorizontalAlignment="Left" Foreground="Gray" />
                        <TextBlock Text="{Binding TotalSGST, StringFormat=₹ {0:N2}}" HorizontalAlignment="Right" Foreground="Gray" FontWeight="SemiBold" />
                    </Grid>
                    <Button Content="SAVE &amp; PRINT BILL" Command="{Binding PrintFinalBillCommand}" Margin="0,16,0,0" Style="{StaticResource MaterialDesignRaisedButton}" Height="40" FontSize="16" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
