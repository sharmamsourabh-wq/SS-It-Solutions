<UserControl x:Class="SolarQuotationBillingSystem.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F0F2F5">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Saved Quotations" FontSize="32" FontWeight="Bold" Margin="0,0,0,24" />

        <materialDesign:Card Grid.Row="1" UniformCornerRadius="8" Background="White" Padding="16">
            <DataGrid ItemsSource="{Binding Quotations}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single"
                      materialDesign:DataGridAssist.CellPadding="12" materialDesign:DataGridAssist.ColumnHeaderPadding="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding QuotationDate, StringFormat=dd-MMM-yyyy}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Quotation No" Binding="{Binding QuotationNo}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Customer Name" Binding="{Binding CustomerName}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Mobile" Binding="{Binding Mobile}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Total Amount" Binding="{Binding GrandTotal, StringFormat=₹ {0:N2}}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" />
                    
                    <DataGridTemplateColumn Header="Action">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Print Quotation -->
                                    <Button Content="Print Quotation" 
                                            Command="{Binding DataContext.PrintQuotationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Height="30" FontSize="11" Cursor="Hand" Margin="2,0" Background="#2196F3" BorderBrush="#2196F3"/>

                                    <!-- Create Bill -->
                                    <Button Content="Create Bill" 
                                            Command="{Binding DataContext.CreateFinalBillCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Height="30" FontSize="11" Cursor="Hand" Margin="2,0" Background="#0288D1" BorderBrush="#0288D1">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Reprint Bill -->
                                    <Button Content="Reprint Bill" 
                                            Command="{Binding DataContext.ReprintBillCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Height="30" FontSize="11" Cursor="Hand" Margin="2,0" Background="#4CAF50" BorderBrush="#4CAF50">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Share WhatsApp -->
                                    <Button Command="{Binding DataContext.ShareWhatsAppCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            ToolTip="Share via WhatsApp" Height="30" Width="30" Padding="0" Margin="5,0,2,0" Foreground="Green">
                                        <materialDesign:PackIcon Kind="Whatsapp" Width="18" Height="18" />
                                    </Button>

                                    <!-- Share Email -->
                                    <Button Command="{Binding DataContext.ShareEmailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            ToolTip="Share via Email" Height="30" Width="30" Padding="0" Margin="2,0" Foreground="Orange">
                                        <materialDesign:PackIcon Kind="EmailOutline" Width="18" Height="18" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>
