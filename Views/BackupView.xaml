<UserControl x:Class="SolarQuotationBillingSystem.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F0F2F5">
    <Grid Margin="16">
        <materialDesign:Card UniformCornerRadius="8" Background="White" Padding="32" MaxWidth="700" HorizontalAlignment="Center" VerticalAlignment="Top">
            <StackPanel>
                <DockPanel Margin="0,0,0,24">
                    <materialDesign:PackIcon Kind="DatabaseExport" Width="40" Height="40" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Database Backup" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Export a safety copy of your Solar ERP database and customer records." Foreground="{DynamicResource MaterialDesignBodyLight}" FontSize="13" />
                    </StackPanel>
                </DockPanel>

                <Separator Margin="0,0,0,24" Background="{DynamicResource MaterialDesignDivider}"/>

                <TextBlock Text="Active Database Location:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4"/>
                <TextBox Text="{Binding DbLocation, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,24"/>

                <Border Background="#E3F2FD" BorderBrush="#2196F3" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Information" Width="24" Height="24" Foreground="#1976D2" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Taking regular backups protects your invoices, quotations, and customer data against hardware failure." TextWrapping="Wrap" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="SemiBold" Margin="0,0,0,24" TextWrapping="Wrap"/>

                <Button Command="{Binding PerformBackupCommand}"
                        Content="Create Backup Now"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="48"
                        FontSize="16"
                        materialDesign:ButtonAssist.CornerRadius="6"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
